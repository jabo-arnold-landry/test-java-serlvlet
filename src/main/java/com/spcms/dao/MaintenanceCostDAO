package com.spcms.dao;

import com.spcms.model.MaintenanceCostDAO;
import com.spcms.util.DBConnection;
import java.sql.*;
import java.time.LocalDate;
import java.util.*;

public class MaintenanceCostDAO {

    public boolean addMaintenanceCostDAO(MaintenanceCost cost) {
        String sql = "INSERT INTO maintenance_cost (ups_maintenance_id, cooling_maintenance_id, equipment_type, parts_cost, labor_cost, vendor_charge, battery_replacement_cost, gas_refill_cost, cost_date, notes) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setObject(1, cost.getUpsMaintenanceId());
            ps.setObject(2, cost.getCoolingMaintenanceId());
            ps.setString(3, cost.getEquipmentType());
            ps.setBigDecimal(4, cost.getPartsCost());
            ps.setBigDecimal(5, cost.getLaborCost());
            ps.setBigDecimal(6, cost.getVendorCharge());
            ps.setBigDecimal(7, cost.getBatteryReplacementCost());
            ps.setBigDecimal(8, cost.getGasRefillCost());
            ps.setDate(9, Date.valueOf(cost.getCostDate()));
            ps.setString(10, cost.getNotes());
            return ps.executeUpdate() > 0;
        } catch (SQLException e) {
            e.printStackTrace();
            return false;
        }
    }

    public List<MaintenanceCostDAO> getCostsByDateRange(LocalDate startDate, LocalDate endDate) {
        String sql = "SELECT * FROM maintenance_cost WHERE cost_date BETWEEN ? AND ? ORDER BY cost_date DESC";
        List<MaintenanceCostDAO> costs = new ArrayList<>();
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setDate(1, Date.valueOf(startDate));
            ps.setDate(2, Date.valueOf(endDate));
            try (ResultSet rs = ps.executeQuery()) {
                while (rs.next()) {
                    costs.add(extractCost(rs));
                }
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        return costs;
    }

    public List<MaintenanceCostDAO> getCostsByEquipmentType(String equipmentType, LocalDate startDate, LocalDate endDate) {
        String sql = "SELECT * FROM maintenance_cost WHERE equipment_type = ? AND cost_date BETWEEN ? AND ? ORDER BY cost_date DESC";
        List<MaintenanceCostDAO> costs = new ArrayList<>();
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, equipmentType);
            ps.setDate(2, Date.valueOf(startDate));
            ps.setDate(3, Date.valueOf(endDate));
            try (ResultSet rs = ps.executeQuery()) {
                while (rs.next()) {
                    costs.add(extractCost(rs));
                }
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        return costs;
    }

    public double getTotalCost(LocalDate startDate, LocalDate endDate) {
        String sql = "SELECT COALESCE(SUM(total_cost), 0) AS total FROM maintenance_cost WHERE cost_date BETWEEN ? AND ?";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setDate(1, Date.valueOf(startDate));
            ps.setDate(2, Date.valueOf(endDate));
            try (ResultSet rs = ps.executeQuery()) {
                if (rs.next()) {
                    return rs.getDouble("total");
                }
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        return 0.0;
    }

    public double getTotalCostByType(String equipmentType, LocalDate startDate, LocalDate endDate) {
        String sql = "SELECT COALESCE(SUM(total_cost), 0) AS total FROM maintenance_cost WHERE equipment_type = ? AND cost_date BETWEEN ? AND ?";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, equipmentType);
            ps.setDate(2, Date.valueOf(startDate));
            ps.setDate(3, Date.valueOf(endDate));
            try (ResultSet rs = ps.executeQuery()) {
                if (rs.next()) {
                    return rs.getDouble("total");
                }
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        return 0.0;
    }

    public Map<String, Double> getCostByEquipmentType(LocalDate startDate, LocalDate endDate) {
        String sql = "SELECT equipment_type, SUM(total_cost) AS total FROM maintenance_cost WHERE cost_date BETWEEN ? AND ? GROUP BY equipment_type";
        Map<String, Double> equipmentCosts = new LinkedHashMap<>();
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setDate(1, Date.valueOf(startDate));
            ps.setDate(2, Date.valueOf(endDate));
            try (ResultSet rs = ps.executeQuery()) {
                while (rs.next()) {
                    equipmentCosts.put(rs.getString("equipment_type"), rs.getDouble("total"));
                }
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }
        return equipmentCosts;
    }

    public boolean updateMaintenanceCost(MaintenanceCost cost) {
        String sql = "UPDATE maintenance_cost SET parts_cost=?, labor_cost=?, vendor_charge=?, battery_replacement_cost=?, gas_refill_cost=?, cost_date=?, notes=?, updated_at=CURRENT_TIMESTAMP WHERE cost_id=?";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setBigDecimal(1, cost.getPartsCost());
            ps.setBigDecimal(2, cost.getLaborCost());
            ps.setBigDecimal(3, cost.getVendorCharge());
            ps.setBigDecimal(4, cost.getBatteryReplacementCost());
            ps.setBigDecimal(5, cost.getGasRefillCost());
            ps.setDate(6, Date.valueOf(cost.getCostDate()));
            ps.setString(7, cost.getNotes());
            ps.setLong(8, cost.getCostId());
            return ps.executeUpdate() > 0;
        } catch (SQLException e) {
            e.printStackTrace();
            return false;
        }
    }

    public boolean deleteMaintenanceCost(Long costId) {
        String sql = "DELETE FROM maintenance_cost WHERE cost_id = ?";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setLong(1, costId);
            return ps.executeUpdate() > 0;
        } catch (SQLException e) {
            e.printStackTrace();
            return false;
        }
    }

    private MaintenanceCost extractCost(ResultSet rs) throws SQLException {
        MaintenanceCost cost = new MaintenanceCost();
        cost.setCostId(rs.getLong("cost_id"));
        cost.setUpsMaintenanceId(rs.getObject("ups_maintenance_id") != null ? rs.getLong("ups_maintenance_id") : null);
        cost.setCoolingMaintenanceId(rs.getObject("cooling_maintenance_id") != null ? rs.getLong("cooling_maintenance_id") : null);
        cost.setEquipmentType(rs.getString("equipment_type"));
        cost.setPartsCost(rs.getBigDecimal("parts_cost"));
        cost.setLaborCost(rs.getBigDecimal("labor_cost"));
        cost.setVendorCharge(rs.getBigDecimal("vendor_charge"));
        cost.setBatteryReplacementCost(rs.getBigDecimal("battery_replacement_cost"));
        cost.setGasRefillCost(rs.getBigDecimal("gas_refill_cost"));
        cost.setTotalCost(rs.getBigDecimal("total_cost"));
        cost.setCostDate(rs.getDate("cost_date").toLocalDate());
        cost.setNotes(rs.getString("notes"));
        cost.setCreatedAt(rs.getTimestamp("created_at").toLocalDateTime());
        cost.setUpdatedAt(rs.getTimestamp("updated_at").toLocalDateTime());
        return cost;
    }
}